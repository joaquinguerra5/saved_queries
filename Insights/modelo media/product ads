CREATE OR REPLACE TABLE `peya-food-and-groceries.automated_tables_reports.ms_insights_product_ads_performance`

PARTITION BY
  date

CLUSTER BY
  global_entity_id, country_code, campaign_id, advertiser_id

AS

WITH brand_cpg_exception_list AS (
  SELECT
    *
  FROM
    `peya-data-origins-pro.cl_qcommerce.cpg_brand_mapping_exceptional_list` el
  QUALIFY ROW_NUMBER() OVER latest_update = 1
    WINDOW latest_update AS (
    PARTITION BY global_entity_id, product_cpg, product_brand
    ORDER BY COALESCE(
    SAFE.PARSE_DATE('%d/%m/%Y', is_updated_by_central),
    SAFE.PARSE_DATE('%m/%d/%Y', is_updated_by_central)
) DESC NULLS LAST)
  ORDER BY
    1,2,3
),

products AS (
    SELECT
      qc.global_entity_id,
      qc.product_name,
      pim.product_id AS master_code,
      CASE
        WHEN INSTR(b.barcode,',') > 0 AND STARTS_WITH(b.barcode, "0") = False THEN SUBSTR(b.barcode,1,INSTR(b.barcode,',')-1)
        WHEN INSTR(b.barcode,',') > 0 AND STARTS_WITH(b.barcode, "0") THEN SUBSTR(b.barcode,2,INSTR(b.barcode,',')-2)
        ELSE b.barcode
      END AS barcode,
      COALESCE(sel.correct_product_cpg, el.correct_product_cpg, pim.brand_owner_name, 'Others') AS product_cpg,
      COALESCE(INITCAP(qc.brand_name), INITCAP(pim.brands_name), 'Others') AS product_brand,
      c.master_category_names.level_one,
      c.master_category_names.level_two,
      c.master_category_names.level_three,
      vp.platform_vendor_id AS partner_id,
    FROM `peya-data-origins-pro.cl_dmarts.qc_catalog_products` AS qc
    ,UNNEST(barcodes) AS b
    ,UNNEST(vendor_products) AS vp
    ,UNNEST(master_categories) AS c
    LEFT JOIN
      `peya-data-origins-pro.cl_dmarts.pim_product` pim
    ON
      pim.product_id = qc.pim_product_id
    LEFT JOIN brand_cpg_exception_list  AS el
      ON qc.global_entity_id = el.global_entity_id
      AND COALESCE(pim.brand_owner_name, 'Others') = el.product_cpg
      AND COALESCE(INITCAP(qc.brand_name), INITCAP(pim.brands_name), 'Others') = INITCAP(el.product_brand)
    LEFT JOIN `peya-data-origins-pro.cl_qcommerce.cpg_barcode_mapping_exceptional_list` AS sel
      ON qc.global_entity_id = sel.global_entity_id
      AND COALESCE(el.correct_product_cpg, pim.brand_owner_name, 'Others') = sel.product_cpg
      AND COALESCE(INITCAP(qc.brand_name), INITCAP(pim.brands_name), 'Others') = sel.product_brand
      AND (CASE
        WHEN INSTR(b.barcode,',') > 0 AND STARTS_WITH(b.barcode, "0") = False THEN SUBSTR(b.barcode,1,INSTR(b.barcode,',')-1)
        WHEN INSTR(b.barcode,',') > 0 AND STARTS_WITH(b.barcode, "0") THEN SUBSTR(b.barcode,2,INSTR(b.barcode,',')-2)
        ELSE b.barcode
      END) = sel.barcode
    QUALIFY ROW_NUMBER() OVER latest_chain = 1
    WINDOW latest_chain AS (
    PARTITION BY qc.global_entity_id, pim.product_id, vp.platform_vendor_id
    ORDER BY qc.chain_product_created_at_utc DESC NULLS LAST)
)


SELECT
  date,
  ads.global_entity_id,
  dc.country_code,
  dc.country_name,
  account_name as advertiser_name,
  account_id as advertiser_id,
  account_type as advertiser_type,
  campaign_id,
  campaign_name,
  STRING(NULL) as cpg,
  DATE(campaign_start_date) as started_at,
  DATE(campaign_end_date) as ended_at,
  'dh_ads' as implemented_at,
  CASE
    WHEN (REGEXP_CONTAINS(lower(campaign_name),'upselling') OR campaign_type = 'AD_FORMAT_PRODUCT_AD') THEN 'Conversion'
    ELSE 'Consideration'
  END as funnel,
  CASE 
    WHEN REGEXP_CONTAINS(lower(campaign_name),'upselling') THEN 'Upselling'
    WHEN asset_type = 'AD_TYPE_SEARCH' AND placement = 'SCREEN_VENDOR_HOME' THEN 'Keyword Search'
    WHEN asset_type = 'AD_TYPE_LISTING' AND placement = 'SCREEN_SUB_CATEGORY' THEN 'Sponsored Products'
    WHEN asset_type = 'AD_TYPE_BANNER_SHOPPABLE' THEN 'Shoppable Banner'
    WHEN asset_type = 'AD_TYPE_BANNER_NO_ACTION' AND placement = 'SCREEN_VENDOR_HOME' THEN 'Vendor Banner'
    WHEN asset_type = 'AD_TYPE_BANNER_LANDING' AND placement = 'SCREEN_VENDOR_HOME' THEN 'Vendor Banner'
    WHEN asset_type = 'AD_TYPE_BANNER_LANDING' AND placement = 'SCREEN_CATEGORY' THEN 'Category Banner'
    WHEN asset_type = 'AD_TYPE_BANNER_LANDING' AND placement = 'SCREEN_VERTICAL_HOME_PRESEARCH' THEN 'QC Presearch'
    WHEN asset_type = 'AD_TYPE_BANNER_LANDING' AND placement = 'SCREEN_VERTICAL_HOME' THEN 'Vertical Banner'
    ELSE 'Otros'
  END as tool_name,
  CASE campaign_type
    WHEN 'AD_FORMAT_PRODUCT_AD' THEN 'product_ads'
    WHEN 'AD_FORMAT_DISPLAY_AD' THEN 'display_ads'
  END as tool_type,
  CASE
    WHEN campaign_name LIKE 'MS_%'THEN 1
    WHEN  campaign_name LIKE 'PS_%'THEN 1
    ELSE 0
  END as is_partnership,
  CASE campaign_type
    WHEN 'AD_FORMAT_PRODUCT_AD' THEN 'cpc'
    WHEN 'AD_FORMAT_DISPLAY_AD' THEN 'cpm'
  END as cost_model,
  product_master_code,
  ads.product_name,
  p.product_brand,
  p.product_cpg,
  p.level_one,
  p.level_two,
  p.level_three,
  category_group_name,
  search_keyword,
  MAX(campaign_budget) as total_budget_local,
  MAX(SAFE_DIVIDE(campaign_budget,rate_eu)) as total_budget_eur,
  SUM(ad_spend) as ad_spend_local,
  SUM(SAFE_DIVIDE(ad_spend,rate_eu)) as ad_spend_eur,
  SUM(impressions) as loaded_impressions,
  SUM(total_clicks) as clicks,
  SUM(campaign_orders) as orders,
  SUM(sales_revenue) as gmv_local,
  SUM(SAFE_DIVIDE(sales_revenue,rate_eu)) as gmv_eur,
  SUM(unit_sold) as units,
FROM
  `peya-data-origins-pro.cl_adtech.qcadtech_agg_dmp_v2` ads
LEFT JOIN
  `peya-bi-tools-pro.il_core.dim_country` dc
ON
  dc.global_entity_id = ads.global_entity_id
LEFT JOIN
    `peya-bi-tools-pro.il_core.dim_currency_exchange` AS dim_currency_exchange
ON
  dim_currency_exchange.currency_exchange_date = DATE_TRUNC(ads.date, month)
  AND dim_currency_exchange.currency_id = dc.currency_id
LEFT JOIN
  products p
ON
  p.master_code = ads.product_master_code AND p.partner_id = ads.vendor_id
WHERE
  date >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(),INTERVAL 13 MONTH),MONTH)
AND
  product_master_code IS NOT NULL
AND
  campaign_type = 'AD_FORMAT_PRODUCT_AD'
GROUP BY
  ALL